{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "dataagents",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "dataagents"
  },
  "runtimes": [
    {
      "name": "orchestrator",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/orchestrator/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "AGUI"
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [
    {
      "name": "orchestratorConfig",
      "type": "ConfigurationBundle",
      "description": "Configuration for orchestrator — managed by agentcore CLI",
      "components": {
        "{{runtime:orchestrator}}": {
          "configuration": {
            "systemPrompt": "You are a helpful assistant. Use tools when appropriate.",
            "toolDescriptions": {
              "add_numbers": "Return the sum of two numbers"
            }
          }
        }
      },
      "branchName": "mainline",
      "commitMessage": "Initial configuration"
    }
  ],
  "abTests": [],
  "httpGateways": [],
  "harnesses": [],
  "datasets": [],
  "payments": []
}